{
  "name": "@claude-dashboard/electron",
  "version": "0.14.0",
  "private": true,
  "description": "Desktop app for Claude Dashboard",
  "author": "Claude Dashboard",
  "repository": "github:stefan-dochez/claude-dashboard",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc && electron dist/main.js --dev",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "package": "electron-builder"
  },
  "dependencies": {},
  "devDependencies": {
    "app-builder-bin": "^5.0.0-alpha.10",
    "electron": "33.4.11",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.3"
  },
  "build": {
    "appId": "com.claude-dashboard.app",
    "productName": "Claude Dashboard",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend/dist",
        "to": "backend/dist"
      },
      {
        "from": "../backend/package.json",
        "to": "backend/package.json"
      },
      {
        "from": "../backend/_pkg/node_modules",
        "to": "backend/node_modules"
      },
      {
        "from": "../frontend/dist",
        "to": "frontend"
      },
      {
        "from": "assets",
        "to": "icon"
      }
    ],
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns",
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
